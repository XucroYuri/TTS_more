# Runtime data
TTS_MORE_REPO_ROOT=repo
TTS_MORE_SERVICE_MODE=real
TTS_MORE_ADAPTER_MODE=real
TTS_MORE_PYTHON_EXE=.venv\\Scripts\\python.exe
# TTS_MORE_BASE_PYTHON=C:\\Path\\To\\Python310\\python.exe

# Service endpoints are read from data/services.json by default.
# Local services must be running on their configured ports to be considered available.
# TTS_MORE_INDEXTTS_MODEL_DIR=repo\\index-tts\\checkpoints
# INDEXTTS2_MODEL_DIR=repo\\index-tts\\checkpoints
# TTS_MORE_INDEXTTS_PYTHON=repo\\index-tts\\.venv\\Scripts\\python.exe

# Commercial TTS providers. Leave unset to keep those services visible but unavailable.
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# XAI_API_KEY=
# VOLCENGINE_APP_ID=
# VOLCENGINE_ACCESS_TOKEN=
# VOLCENGINE_CLUSTER_ID=

# Multi-provider OpenAI-compatible parser configuration.
# Keys are referenced by env var name and should be stored in an ignored .env.local file.
# 开物基模 is preset in the UI with base_url=https://kwjm.com and model=gpt-5.5.
# KWJM_API_KEY=
# TTS_MORE_PARSER_PROVIDERS=[{"name":"开物基模","base_url":"https://kwjm.com","api_key_env":"KWJM_API_KEY","model":"gpt-5.5","enabled":true}]
