# Runtime data
TTS_MORE_REPO_ROOT=repo
TTS_MORE_SERVICE_MODE=real
TTS_MORE_ADAPTER_MODE=real
# Python venv interpreter. Use the path matching your host:
#   macOS / Linux : .venv/bin/python
#   Windows       : .venv\Scripts\python.exe
TTS_MORE_PYTHON_EXE=.venv/bin/python
# TTS_MORE_BASE_PYTHON=/path/to/python3.11

# Optional shared API token. When set, mutating/egress endpoints require an
# "Authorization: Bearer <token>" header. Leave unset for open local mode.
# TTS_MORE_API_TOKEN=

# Optional operator allowlists (os.pathsep-separated):
# TTS_MORE_ALLOWED_EXECUTABLES=python;python3;node
# TTS_MORE_ALLOWED_DATA_ROOTS=/mnt/nas/models
# TTS_MORE_MAX_UPLOAD_BYTES=26214400


# Service endpoints are read from data/services.json by default.
# Local services must be running on their configured ports to be considered available.
# TTS_MORE_INDEXTTS_MODEL_DIR=repo\\index-tts\\checkpoints
# INDEXTTS2_MODEL_DIR=repo\\index-tts\\checkpoints
# TTS_MORE_INDEXTTS_PYTHON=repo\\index-tts\\.venv\\Scripts\\python.exe

# Commercial TTS providers. Leave unset to keep those services visible but unavailable.
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# XAI_API_KEY=
# VOLCENGINE_APP_ID=
# VOLCENGINE_ACCESS_TOKEN=
# VOLCENGINE_CLUSTER_ID=

# Multi-provider parser configuration.
# Keys are referenced by env var name and should be stored in an ignored .env.local file.
# Providers ship disabled by default; enable the ones you have a key for.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# OPENROUTER_API_KEY=
# AIHUBMIX_API_KEY=
# ZHIPU_API_KEY=
# DEEPSEEK_API_KEY=
# DASHSCOPE_API_KEY=
# MOONSHOT_API_KEY=
# ARK_API_KEY=
# YI_API_KEY=
# XAI_API_KEY=
# GROQ_API_KEY=
# 开物基模 is preset last as a project-specific fallback (base_url=https://kwjm.com, model=gpt-5.5).
# KWJM_API_KEY=
# TTS_MORE_PARSER_PROVIDERS=[{"name":"OpenAI","adapter":"openai-compatible","base_url":"https://api.openai.com/v1","api_key_env":"OPENAI_API_KEY","model":"gpt-5.5","enabled":true}]
