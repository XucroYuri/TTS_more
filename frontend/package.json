{
  "name": "tts-more-workstation",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc && vite build",
    "test": "vitest run --exclude=e2e/**",
    "test:cuda-fixture": "vitest run e2e/cuda-fixture.test.ts",
    "cuda:e2e": "playwright test e2e/cuda-workstation.spec.ts",
    "cuda:e2e:install": "playwright install chromium"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.2",
    "i18next": "^26.3.3",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^0.562.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-i18next": "^17.0.8",
    "vite": "^7.3.0",
    "wavesurfer.js": "^7.12.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.1.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.17"
  }
}
