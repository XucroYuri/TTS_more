{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TTS More portable component package",
  "type": "object",
  "required": [
    "schema_version",
    "component",
    "version",
    "build_id",
    "api_contract",
    "default_endpoint",
    "port",
    "launcher",
    "health_path",
    "capabilities",
    "model_profile",
    "runtime",
    "sha256_manifest"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "component": {"type": "string", "minLength": 1},
    "version": {"type": "string", "minLength": 1},
    "build_id": {"type": "string", "minLength": 1},
    "api_contract": {"const": "tts-more-v1"},
    "default_endpoint": {"type": "string", "pattern": "^http://"},
    "port": {"type": "integer", "minimum": 1, "maximum": 65535},
    "launcher": {"type": "string", "minLength": 1},
    "health_path": {"const": "/health"},
    "capabilities": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "model_profile": {"type": "string", "minLength": 1},
    "runtime": {"type": "string", "minLength": 1},
    "sha256_manifest": {"type": "string", "minLength": 1}
  },
  "additionalProperties": false
}
